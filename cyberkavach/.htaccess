# Basic security headers and rewrite rules (scaffold)\n<IfModule mod_rewrite.c>\n  RewriteEngine On\n  RewriteBase /\n  RewriteCond %{REQUEST_FILENAME} !-f\n  RewriteCond %{REQUEST_FILENAME} !-d\n  RewriteRule ^ index.php [L,QSA]\n</IfModule>\n\n<IfModule mod_headers.c>\n  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' cdn.jsdelivr.net; img-src 'self' data: res.cloudinary.com; font-src 'self' fonts.gstatic.com"\n  Header always set X-Frame-Options "DENY"\n  Header always set X-Content-Type-Options "nosniff"\n  Header always set Referrer-Policy "strict-origin-when-cross-origin"\n  Header always set Permissions-Policy "geolocation=(self), camera=(self)"\n  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"\n</IfModule>\n